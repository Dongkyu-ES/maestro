{
  "name": "dominic-orchestration",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "bin": {
    "agent": "./dist/cli.js"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "test": "npm run build && node --test \"dist/**/*.test.js\"",
    "lint": "biome lint src scripts",
    "format": "biome format --write src scripts",
    "check": "biome check --write src scripts",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "e2e": "node scripts/operator-browser-e2e.mjs && node scripts/operator-codex-web-e2e.mjs",
    "report:github": "node scripts/github-projects-report.mjs",
    "harness:integrity": "node scripts/harness-os-integrity-gate.mjs",
    "harness:integrity:self-test": "node scripts/harness-os-integrity-gate.mjs --self-test",
    "harness:goal-reachability": "node scripts/goal-reachability-harness.mjs",
    "harness:goal-reachability:self-test": "node scripts/goal-reachability-harness.mjs --self-test",
    "harness:compare": "npm run build && node scripts/harness-compare.mjs",
    "harness:compare:self-test": "npm run build && node scripts/harness-compare.mjs --self-test",
    "harness:executors-compare": "npm run build && node scripts/harness-executors-compare.mjs",
    "harness:orchestration-demo": "npm run build && node scripts/harness-orchestration-demo.mjs",
    "harness:review-custody-preflight": "node scripts/review-custody-preflight.mjs",
    "harness:review-custody-preflight:self-test": "node scripts/review-custody-preflight.mjs --self-test",
    "harness:review-custody-bootstrap": "node scripts/review-custody-bootstrap.mjs",
    "harness:review-custody-bootstrap:self-test": "node scripts/review-custody-bootstrap.mjs --self-test",
    "harness:review-custody-comment-validate": "node scripts/review-custody-comment-validate.mjs",
    "harness:review-custody-comment-validate:self-test": "node scripts/review-custody-comment-validate.mjs --self-test"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.16",
    "@types/node": "^22.15.29",
    "typescript": "^5.8.3"
  }
}
