# Generated artifacts (presentations, reports)
outputs/
reports/

# OS/editor
.DS_Store
*.swp

# Node / build artifacts
node_modules/
# dist/ is intentionally committed: it ships as the bundled engine for the
# Claude Code plugin (bin/maestro -> dist/cli.js). Rebuild + recommit on change.
# Test artifacts inside dist/ are excluded to keep the plugin payload lean.
dist/**/*.test.js
dist/**/*.test.d.ts
dist/**/*.test.js.map
build/
coverage/
.env
.env.*

# Goal reachability volatile generated reports
_workspace/goal-reachability/final/
